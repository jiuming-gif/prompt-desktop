{
  "name": "prompt-desktop",
  "version": "1.0.0",
  "description": "三栏 AI 桌面端 - DeepSeek / Kimi / 豆包",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& electron-builder --win nsis",
    "build:portable": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/&& electron-builder --win portable"
  },
  "build": {
    "appId": "com.prompt.desktop",
    "productName": "PromptDesktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "style.css"
    ],
    "compression": "maximum",
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "PromptDesktop-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  }
}
